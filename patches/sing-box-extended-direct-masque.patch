+
+func (w *Outbound) createDirectConfig() (*Config, error) {
+	if w.options.Server == "" || w.options.PrivateKey == "" || w.options.PublicKey == "" {
+		return nil, E.New("direct MASQUE requires server, private_key and public_key")
+	}
+	server := w.options.Server
+	if net.ParseIP(server) == nil {
+		return nil, E.New("direct MASQUE server must be an IP address")
+	}
+	config := &Config{
+		PrivateKey:     w.options.PrivateKey,
+		EndpointV4:     server,
+		EndpointH2V4:   server,
+		EndpointPubKey: w.options.PublicKey,
+	}
+	for _, prefix := range w.options.Address {
+		address := prefix.Addr().Unmap()
+		if address.Is4() {
+			config.IPv4 = address.String()
+		} else if address.Is6() {
+			config.IPv6 = address.String()
+		}
+	}
+	if config.IPv4 == "" && config.IPv6 == "" {
+		return nil, E.New("direct MASQUE requires at least one address")
+	}
+	if config.IPv6 != "" {
+		config.EndpointV6 = server
+		config.EndpointH2V6 = server
+	}
+	return config, nil
+}
